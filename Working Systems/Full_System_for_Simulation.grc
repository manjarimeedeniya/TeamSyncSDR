- name: epy_block_5
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\nimport numpy as np\n\n\nclass\
      \ pdu_unpadder(gr.basic_block):\n    \"\"\"\n    Removes pad_len bytes from\
      \ the *end* of each PDU:\n\n        [DATA | PAD...] -> [DATA]\n\n    Must use\
      \ the same pad_len as pdu_padder.\n    \"\"\"\n\n    def __init__(self, pad_len=256):\n\
      \        gr.basic_block.__init__(self,\n                                name=\"\
      pdu_unpadder\",\n                                in_sig=None,\n            \
      \                    out_sig=None)\n\n        self.pad_len = int(pad_len)\n\n\
      \        self.message_port_register_in(pmt.intern(\"in\"))\n        self.message_port_register_out(pmt.intern(\"\
      out\"))\n        self.set_msg_handler(pmt.intern(\"in\"), self.handle_msg)\n\
      \n    def _update_length_meta(self, meta, new_len):\n        if not pmt.is_dict(meta):\n\
      \            return meta\n        for key_str in [\"packet_len\", \"pdu_len\"\
      , \"length\"]:\n            key = pmt.intern(key_str)\n            if pmt.dict_has_key(meta,\
      \ key):\n                meta = pmt.dict_add(meta, key, pmt.from_long(new_len))\n\
      \        return meta\n\n    def handle_msg(self, msg):\n        if not pmt.is_pair(msg)\
      \ or self.pad_len <= 0:\n            return self.message_port_pub(pmt.intern(\"\
      out\"), msg)\n\n        meta = pmt.car(msg)\n        vec = pmt.cdr(msg)\n  \
      \      if not pmt.is_u8vector(vec):\n            return self.message_port_pub(pmt.intern(\"\
      out\"), msg)\n\n        data = np.frombuffer(bytes(pmt.u8vector_elements(vec)),\
      \ dtype=np.uint8)\n        length = len(data)\n\n        if length <= self.pad_len:\n\
      \            # Too short to safely strip pad \u2013 forward unchanged\n    \
      \        return self.message_port_pub(pmt.intern(\"out\"), msg)\n\n        new_data\
      \ = data[: length - self.pad_len]\n\n        meta = self._update_length_meta(meta,\
      \ len(new_data))\n        new_vec = pmt.init_u8vector(len(new_data), new_data.tolist())\n\
      \        new_msg = pmt.cons(meta, new_vec)\n        self.message_port_pub(pmt.intern(\"\
      out\"), new_msg)\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    pad_len: '256'
  states:
    _io_cache: ('pdu_unpadder', 'pdu_unpadder', [('pad_len', '256')], [('in', 'message',
