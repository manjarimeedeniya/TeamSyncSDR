- name: epy_block_0
  id: epy_block
  parameters:
    _source_code: "\"\"\"\nEmbedded Python Blocks:\n\nEach time this file is saved,\
      \ GRC will instantiate the first class it finds\nto get ports and parameters\
      \ of your block. The arguments to __init__  will\nbe the parameters. All of\
      \ them are required to have default values!\n\"\"\"\n\nimport numpy as np\n\
      from gnuradio import gr\nimport time\n\n# Map your source IDs to TDMA slot numbers\n\
      USER_SLOT_MAP = {\n    0x01: 0,  # User A\n    0x02: 1,  # User B\n    0x03:\
      \ 2,  # User C\n    0x04: 3,  # User D\n    0x05: 4   # User E\n}\n\nclass tdma_scheduler(gr.basic_block):\n\
      \    \"\"\"\n    TDMA Scheduler Block\n    Reads the first byte of a packet\
      \ (src_id) and gates transmission \n    based on the wall-clock time slot.\n\
      \    \"\"\"\n\n    def __init__(self, slot_len_ms=1.5, num_slots=4):\n     \
      \   gr.basic_block.__init__(\n            self,\n            name=\"tdma_scheduler_auto\"\
      ,\n            in_sig=[np.uint8],   # Input: Bytes (Orange)\n            out_sig=[np.uint8]\
      \   # Output: Bytes (Orange)\n        )\n\n        self.slot_len = float(slot_len_ms)\
      \ / 1000.0\n        self.num_slots = int(num_slots)\n        self.frame_len\
      \ = self.slot_len * self.num_slots\n        self.time_offset = 0.0\n\n     \
      \   # Store the slot number of the current packet\n        self.current_slot\
      \ = None\n\n    def general_work(self, input_items, output_items):\n       \
      \ inp = input_items[0]\n        out = output_items[0]\n        \n        # SAFETY:\
      \ Calculate 'n' based on the smaller buffer to prevent overflows\n        n\
      \ = min(len(inp), len(out))\n        \n        if n == 0:\n            return\
      \ 0\n\n        # Logic: Check user ID from the first byte of the chunk\n   \
      \     # Note: The code currently attempts to read index 8 (inp[8])\n       \
      \ if n > 8: # Ensure the buffer is large enough for index 8\n            src_id\
      \ = int(inp[8])\n            \n            # --- DEBUG PRINT COMMAND INSERTED\
      \ HERE ---\n            if src_id in USER_SLOT_MAP:\n                print(f\"\
      [TDMA] Reading Source ID: 0x{src_id:02X} -> Slot {USER_SLOT_MAP[src_id]}\")\n\
      \            else:\n                print(f\"[TDMA] Reading Source ID: 0x{src_id:02X}\
      \ (Unmapped)\")\n            # ----------------------------------------\n  \
      \          \n            # Only update slot if the ID is found in our map\n\
      \            if src_id in USER_SLOT_MAP:\n                self.current_slot\
      \ = USER_SLOT_MAP[src_id]\n\n        # Compute current time in the TDMA frame\n\
      \        # (Using system time for basic synchronization)\n        now = (time.time()\
      \ + self.time_offset) % self.frame_len\n\t\n        # Gating Logic\n       \
      \ if self.current_slot is not None:\n            slot_start = self.current_slot\
      \ * self.slot_len\n            slot_end = slot_start + self.slot_len\n\n   \
      \         if slot_start <= now < slot_end:\n                out[:n] = inp[:n]\
      \  # Transmit data\n            else:\n                out[:n] = 0        #\
      \ Block data (send zeros)\n        else:\n            # If no user ID is recognized\
      \ yet, block data\n            out[:n] = 0\n\n        # Tell GNU Radio we consumed\
      \ 'n' items\n        self.consume(0, n)\n        return n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    num_slots: '4'
    slot_len_ms: '1.5'
  states:
    _io_cache: ('tdma_scheduler_auto', 'tdma_scheduler', [('slot_len_ms', '1.5'),
      ('num_slots', '4')], [('0', 'byte', 1)], [('0', 'byte', 1)], '\n    TDMA Scheduler
      Block\n    Reads the first byte of a packet (src_id) and gates transmission
      \n    based on the wall-clock time slot.\n    ', ['num_slots'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [224, 328.0]
    rotation: 0
    state: enabled
- name: epy_block_0_0
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\nclass blk(gr.basic_block):\n\
      \    def __init__(self, target_file=\"output.txt\", append_mode=False):\n  \
      \      gr.basic_block.__init__(\n            self,\n            name=\"pdu_to_file_sink\"\
      ,\n            in_sig=[],\n            out_sig=[]\n        )\n\n        # Output\
      \ file path\n        self.file_target = target_file\n        # Append mode flag:\
      \ True = append, False = overwrite\n        self.do_append = append_mode\n\n\
      \        # Input port for PDUs\n        self.message_port_register_in(pmt.intern(\"\
      pdus\"))\n        self.set_msg_handler(pmt.intern(\"pdus\"), self.write_pdu_to_file)\n\
      \n        # Clear file at startup if not appending\n        if not self.do_append:\n\
      \            with open(self.file_target, \"wb\"):\n                pass  # Just\
      \ open and close to clear the file\n\n    def write_pdu_to_file(self, msg):\n\
      \        \"\"\"Save the payload of an incoming PDU to disk\"\"\"\n        header_info\
      \ = pmt.car(msg)\n        payload_pmt = pmt.cdr(msg)\n\n        # Only process\
      \ valid u8vector PDUs\n        if pmt.is_u8vector(payload_pmt):\n          \
      \  payload_bytes = bytes(pmt.u8vector_elements(payload_pmt))\n\n           \
      \ # Write payload to file in append mode\n            with open(self.file_target,\
      \ \"ab\") as file_handle:\n                file_handle.write(payload_bytes)\n\
      \n            # Optional log for debugging\n            print(f\"[PDU Writer]\
      \ Wrote {len(payload_bytes)} bytes to '{self.file_target}'\")\n"
    affinity: ''
    alias: ''
    append_mode: 'False'
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    target_file: r"output.txt"
  states:
    _io_cache: ('pdu_to_file_sink', 'blk', [('target_file', "'output.txt'"), ('append_mode',
      'False')], [('pdus', 'message', 1)], [], '', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [2136, 976.0]
    rotation: 0
    state: enabled
- name: epy_block_1
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\nimport numpy as np\n\nclass\
      \ pdu_garbage_injector(gr.basic_block):\n    \"\"\"\n    Sends a randomly generated\
      \ 256-byte garbage PDU once,\n    then forwards all normal PDUs afterwards.\n\
      \    \"\"\"\n\n    def __init__(self):\n        gr.basic_block.__init__(\n \
      \           self,\n            name=\"pdu_garbage_injector\",\n            in_sig=None,\n\
      \            out_sig=None,\n        )\n\n        # Register PDU ports\n    \
      \    self.message_port_register_in(pmt.intern(\"in\"))\n        self.message_port_register_out(pmt.intern(\"\
      out\"))\n\n        # --- Generate 256 random bytes (0\u2013255 each) ---\n \
      \       garbage = np.random.randint(0, 256, 256, dtype=np.uint8)\n\n       \
      \ # Convert to PMT PDU\n        self.garbage_pdu = pmt.cons(\n            pmt.PMT_NIL,\n\
      \            pmt.init_u8vector(len(garbage), garbage)\n        )\n\n       \
      \ self.sent = False\n\n        # Send garbage packet immediately at startup\n\
      \        self.message_port_pub(pmt.intern(\"out\"), self.garbage_pdu)\n    \
      \    self.sent = True\n\n        # Install handler for input PDUs\n        self.set_msg_handler(pmt.intern(\"\
      in\"), self.handle_msg)\n\n    def handle_msg(self, msg):\n        \"\"\"\n\
      \        Forward all incoming PDUs after garbage was sent.\n        \"\"\"\n\
      \        if not pmt.is_pair(msg):\n            return\n\n        # Forward incoming\
      \ PDU normally\n        self.message_port_pub(pmt.intern(\"out\"), msg)\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('pdu_garbage_injector', 'pdu_garbage_injector', [], [('in', 'message',
      1)], [('out', 'message', 1)], '\n    Sends a randomly generated 256-byte garbage
      PDU once,\n    then forwards all normal PDUs afterwards.\n    ', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [496, 168.0]
    rotation: 0
    state: enabled
- name: epy_block_1_0
  id: epy_block
  parameters:
    _source_code: "import pmt\nimport threading\nimport time\nfrom gnuradio import\
      \ gr\n\nUSER_IDS = {\n    \"A\": 0x01,\n    \"B\": 0x02,\n    \"C\": 0x03,\n\
      \    \"D\": 0x04,\n    \"E\": 0x05\n}\n\nclass blk(gr.basic_block):\n    def\
      \ __init__(self, input_file=\"\", send_interval=1.0, packet_limit=32,\n    \
      \             sender_id=0x01, receiver_id=0x02, max_attempts=100):\n       \
      \ gr.basic_block.__init__(\n            self,\n            name=\"file_to_pdu_sender\"\
      ,\n            in_sig=[],\n            out_sig=[]\n        )\n\n        # Parameters\n\
      \        self.source_file = input_file\n        self.interval_sec = float(send_interval)\n\
      \        self.max_packet_len = int(packet_limit)\n        self.node_src_id =\
      \ sender_id\n        self.node_dst_id = receiver_id\n        self.max_attempts\
      \ = int(max_attempts)\n\n        # Ports\n        self.message_port_register_out(pmt.intern(\"\
      pdus\"))\n        self.message_port_register_in(pmt.intern(\"ack_bits\"))\n\
      \        self.set_msg_handler(pmt.intern(\"ack_bits\"), self.handle_ack)\n\n\
      \        # Threading & ACK tracking\n        self.stop_event = threading.Event()\n\
      \        self.ack_event = threading.Event()\n        self.expected_ack = None\n\
      \        self.lock = threading.Lock()\n\n        # bookkeeping\n        self.acked_packets\
      \ = set()\n        self.skipped_packets = []\n        self.total_sent_packets\
      \ = 0\n\n        # Sender thread\n        self.sender_thread = threading.Thread(target=self._send_loop)\n\
      \        self.sender_thread.daemon = True\n        self._thread_started = False\n\
      \n    def start(self):\n        # Ensure we only start the sender thread once\n\
      \        self.stop_event.clear()\n        if not self._thread_started:\n   \
      \         self.sender_thread.start()\n            self._thread_started = True\n\
      \        # return value follows GNU Radio convention\n        try:\n       \
      \     return super().start()\n        except Exception:\n            return\
      \ True\n\n    def stop(self):\n        self.stop_event.set()\n        self.ack_event.set()\
      \  # unblock waiting\n        if self._thread_started and self.sender_thread.is_alive():\n\
      \            self.sender_thread.join(timeout=1.0)\n        try:\n          \
      \  return super().stop()\n        except Exception:\n            return True\n\
      \n    def _send_loop(self):\n        try:\n            with open(self.source_file,\
      \ 'rb') as f:\n                raw_data = f.read()\n        except Exception\
      \ as e:\n            print(f\"[PDU Sender] Failed to read file: {str(e)}\")\n\
      \            return\n\n        # Split into packets (3 bytes reserved for header)\n\
      \        chunks = [\n            raw_data[i:i + self.max_packet_len - 3]\n \
      \           for i in range(0, len(raw_data), self.max_packet_len - 3)\n    \
      \    ]\n\n        pkt_num = 1  # Start numbering at 1\n\n        for chunk in\
      \ chunks:\n            if self.stop_event.is_set():\n                break\n\
      \n            full_packet = bytes([self.node_src_id, self.node_dst_id, pkt_num])\
      \ + chunk\n            pdu_payload = pmt.init_u8vector(len(full_packet), list(full_packet))\n\
      \            pdu_msg = pmt.cons(pmt.make_dict(), pdu_payload)\n\n          \
      \  # prepare to wait for ACK for this packet\n            with self.lock:\n\
      \                self.expected_ack = pkt_num\n                self.ack_event.clear()\n\
      \n            attempt = 0\n            got_ack = False\n\n            # Attempt\
      \ up to max_attempts\n            while not self.stop_event.is_set() and attempt\
      \ < self.max_attempts:\n                self.message_port_pub(pmt.intern(\"\
      pdus\"), pdu_msg)\n                self.total_sent_packets += 1\n          \
      \      print(f\"[PDU Sender] Packet #{pkt_num:02X} sent (try {attempt+1})\"\
      )\n\n                # Wait for ACK (sets by handler)\n                ack_received\
      \ = self.ack_event.wait(timeout=self.interval_sec)\n\n                if ack_received:\n\
      \                    # verify that the handler matched the expected ack (handler\
      \ only sets when match)\n                    with self.lock:\n             \
      \           if pkt_num in self.acked_packets:\n                            got_ack\
      \ = True\n                    if got_ack:\n                        break\n \
      \                   # If ack_event was set but ack didn't correspond, continue\
      \ retrying\n                else:\n                    # timeout\n         \
      \           attempt += 1\n                    print(f\"[PDU Sender] Timeout\
      \ waiting for ACK for packet #{pkt_num:02X} (attempt {attempt})\")\n\n     \
      \       if got_ack:\n                print(f\"[PDU Sender] Confirmed ACK for\
      \ packet #{pkt_num:02X}\")\n            else:\n                # Reached max_attempts\
      \ without correct ACK -> skip this packet and continue\n                print(f\"\
      [PDU Sender] No ACK after {self.max_attempts} tries for packet #{pkt_num:02X},\
      \ skipping...\")\n                self.skipped_packets.append(pkt_num)\n   \
      \             # ensure ack_event is cleared before moving on\n             \
      \   with self.lock:\n                    self.ack_event.clear()\n          \
      \          # Note: expected_ack will be overwritten for next packet\n\n    \
      \        # increment packet number (wrap 1..255)\n            pkt_num = (pkt_num\
      \ + 1) & 0xFF\n            if pkt_num == 0x00:\n                pkt_num = 0x01\n\
      \n        # finished sending (either end of file or stop event)\n        print(\"\
      [PDU Sender] Send loop finished.\")\n        print(f\"  Total PDUs transmitted\
      \ attempts: {self.total_sent_packets}\")\n        print(f\"  ACKed packets (count):\
      \ {len(self.acked_packets)} -> {sorted(self.acked_packets)}\")\n        print(f\"\
      \  Skipped packets (count): {len(self.skipped_packets)} -> {self.skipped_packets}\"\
      )\n\n    def handle_ack(self, msg):\n        \"\"\"Process incoming ACK\"\"\"\
      \n        # msg might be a PMT pair (meta, u8vector) or already the u8vector\
      \ depending on sender\n        try:\n            if pmt.is_pair(msg):\n    \
      \            ack_data = pmt.cdr(msg)\n            else:\n                ack_data\
      \ = msg\n        except Exception:\n            print(\"[PDU Sender] ACK handler\
      \ received unexpected PMT message\")\n            return\n\n        if not pmt.is_u8vector(ack_data):\n\
      \            print(\"[PDU Sender] Invalid ACK format (not u8vector)\")\n   \
      \         return\n\n        ack_bytes = bytearray(pmt.u8vector_elements(ack_data))\n\
      \        print(f\"[PDU Sender] Raw ACK received: {list(ack_bytes)}\")  # DEBUG\n\
      \n        if len(ack_bytes) < 2 or ack_bytes[0] != 0xAA:\n            print(\"\
      [PDU Sender] Invalid ACK header or too short\")\n            return\n\n    \
      \    ack_num = ack_bytes[1]\n        with self.lock:\n            # Only set\
      \ the event if ACK matches the expected packet number\n            if ack_num\
      \ == self.expected_ack:\n                print(f\"[PDU Sender] ACK matches expected\
      \ packet #{ack_num:02X} -- setting event\")\n                self.acked_packets.add(ack_num)\n\
      \                self.ack_event.set()\n            else:\n                #\
      \ ACK for some other packet (maybe a late ACK) -> ignore\n                print(f\"\
      [PDU Sender] ACK for packet #{ack_num:02X} does not match expected #{self.expected_ack:02X},\
      \ ignoring\")\n"
    affinity: ''
    alias: ''
    comment: ''
    input_file: r"/home/manjarimanesha/input.txt"
    max_attempts: '1000'
    maxoutbuf: '0'
    minoutbuf: '0'
    packet_limit: '32'
    receiver_id: '2'
    send_interval: '0.01'
    sender_id: '1'
  states:
    _io_cache: ('file_to_pdu_sender', 'blk', [('input_file', "''"), ('send_interval',
      '1.0'), ('packet_limit', '32'), ('sender_id', '1'), ('receiver_id', '2'), ('max_attempts',
      '100')], [('ack_bits', 'message', 1)], [('pdus', 'message', 1)], '', ['max_attempts'])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [232, 120.0]
    rotation: 0
    state: enabled
- name: epy_block_2
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\nUSER_IDS = {\n    \"A\"\
      : 0x01,\n    \"B\": 0x02,\n    \"C\": 0x03,\n    \"D\": 0x04,\n    \"E\": 0x05\n\
      }\n\nclass blk(gr.basic_block):\n    def __init__(self, node_id=0x03):\n   \
      \     gr.basic_block.__init__(\n            self,\n            name=\"addressed_pdu_filter\"\
      ,\n            in_sig=[],\n            out_sig=[]\n        )\n\n        # Receiver\u2019\
      s ID\n        self.receiver_id = node_id\n\n        # Ports\n        self.message_port_register_in(pmt.intern(\"\
      pdus_in\"))\n        self.message_port_register_out(pmt.intern(\"pdus_out\"\
      ))\n        self.message_port_register_out(pmt.intern(\"ack_out\"))\n\n    \
      \    self.set_msg_handler(pmt.intern(\"pdus_in\"), self.handle_incoming_pdu)\n\
      \n        # Stop-and-Wait: expected packet number\n        self.expected_pkt_num\
      \ = 1\n\n    def handle_incoming_pdu(self, msg):\n        pdu_payload = pmt.cdr(msg)\n\
      \n        if not pmt.is_u8vector(pdu_payload):\n            print(\"[Receiver]\
      \ Invalid PDU\")\n            return\n\n        packet_bytes = bytearray(pmt.u8vector_elements(pdu_payload))\n\
      \        if len(packet_bytes) < 3:\n            print(\"[Receiver] Too short\
      \ PDU\")\n            return\n\n        src_id, dest_id, pkt_num = packet_bytes[0],\
      \ packet_bytes[1], packet_bytes[2]\n\n        if dest_id != self.receiver_id:\n\
      \            print(f\"[Receiver] Packet not for me (dest={dest_id:02X})\")\n\
      \            return\n\n        if pkt_num == self.expected_pkt_num:\n      \
      \      # Correct \u2192 deliver payload\n            payload_only = packet_bytes[3:]\n\
      \            payload_pmt = pmt.init_u8vector(len(payload_only), payload_only)\n\
      \            forward_msg = pmt.cons(pmt.make_dict(), payload_pmt)\n        \
      \    self.message_port_pub(pmt.intern(\"pdus_out\"), forward_msg)\n\n      \
      \      print(f\"[Receiver] Accepted packet #{pkt_num:02X}\")\n\n           \
      \ # Update expected\n            self.expected_pkt_num = (self.expected_pkt_num\
      \ + 1) & 0xFF\n            if self.expected_pkt_num == 0x00:\n             \
      \   self.expected_pkt_num = 0x01\n        else:\n            print(f\"[Receiver]\
      \ Unexpected packet #{pkt_num:02X}, expecting #{self.expected_pkt_num:02X}\"\
      )\n\n        # Always ACK last valid packet\n        ack_num = pkt_num if pkt_num\
      \ == (self.expected_pkt_num - 1) else (self.expected_pkt_num - 1) & 0xFF\n \
      \       if ack_num == 0x00:\n            ack_num = 0xFF\n\n        ack_bytes\
      \ = bytes([0xAA, ack_num])\n        ack_msg = pmt.cons(pmt.make_dict(), pmt.init_u8vector(len(ack_bytes),\
      \ list(ack_bytes)))\n\n        # Send ACK multiple times for reliability\n \
      \       for _ in range(5):\n            self.message_port_pub(pmt.intern(\"\
      ack_out\"), ack_msg)\n\n        print(f\"[Receiver] ACK sent for packet #{ack_num:02X}\"\
      )\n"
    affinity: ''
    alias: ''
    comment: ''
