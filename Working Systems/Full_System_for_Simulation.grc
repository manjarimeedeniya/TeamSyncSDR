- name: epy_block_3
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\n\nclass pdu_garbage_remover(gr.basic_block):\n\
      \    \"\"\"\n    Drops the first incoming PDU of 256 bytes (garbage packet),\
      \ \n    then passes everything else.\n    \"\"\"\n\n    def __init__(self):\n\
      \        gr.basic_block.__init__(\n            self,\n            name=\"pdu_garbage_remover\"\
      ,\n            in_sig=None,\n            out_sig=None,\n        )\n\n      \
      \  self.message_port_register_in(pmt.intern(\"in\"))\n        self.message_port_register_out(pmt.intern(\"\
      out\"))\n\n        self.dropped = False  # drop only first PDU\n\n        self.set_msg_handler(pmt.intern(\"\
      in\"), self.handle_msg)\n\n    def handle_msg(self, msg):\n        if not pmt.is_pair(msg):\n\
      \            return\n\n        meta = pmt.car(msg)\n        vec = pmt.cdr(msg)\n\
      \        length = pmt.length(vec)\n\n        # Drop only first 256-byte PDU\n\
      \        if not self.dropped and length == 256:\n            self.dropped =\
      \ True\n            return  # do not output\n\n        # Forward everything\
      \ else\n        self.message_port_pub(pmt.intern(\"out\"), msg)\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    _io_cache: ('pdu_garbage_remover', 'pdu_garbage_remover', [], [('in', 'message',
      1)], [('out', 'message', 1)], '\n    Drops the first incoming PDU of 256 bytes
      (garbage packet), \n    then passes everything else.\n    ', [])
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1896, 992.0]
    rotation: 0
    state: enabled
- name: epy_block_4
  id: epy_block
  parameters:
    _source_code: "import pmt\nfrom gnuradio import gr\nimport numpy as np\n\n\nclass\
      \ pdu_padder(gr.basic_block):\n    \"\"\"\n    Appends pad_len bytes with value\
      \ pattern_byte to the end of each PDU:\n\n        [DATA] -> [DATA | PAD...]\n\
      \n    DATA here is [HEADER | PAYLOAD | CRC] once we rewire.\n    \"\"\"\n\n\
      \    def __init__(self, pad_len=256, pattern_byte=0x55):\n        gr.basic_block.__init__(self,\n\
      \                                name=\"pdu_padder\",\n                    \
      \            in_sig=None,\n                                out_sig=None)\n\n\
      \        self.pad_len = int(pad_len)\n        self.pattern_byte = int(pattern_byte)\
      \ & 0xFF\n        self.pad = np.full(self.pad_len, self.pattern_byte, dtype=np.uint8)\n\
      \n        self.message_port_register_in(pmt.intern(\"in\"))\n        self.message_port_register_out(pmt.intern(\"\
      out\"))\n        self.set_msg_handler(pmt.intern(\"in\"), self.handle_msg)\n\
      \n    def _update_length_meta(self, meta, new_len):\n        if not pmt.is_dict(meta):\n\
      \            return meta\n        for key_str in [\"packet_len\", \"pdu_len\"\
      , \"length\"]:\n            key = pmt.intern(key_str)\n            if pmt.dict_has_key(meta,\
      \ key):\n                meta = pmt.dict_add(meta, key, pmt.from_long(new_len))\n\
      \        return meta\n\n    def handle_msg(self, msg):\n        if not pmt.is_pair(msg)\
      \ or self.pad_len <= 0:\n            return self.message_port_pub(pmt.intern(\"\
      out\"), msg)\n\n        meta = pmt.car(msg)\n        vec = pmt.cdr(msg)\n  \
      \      if not pmt.is_u8vector(vec):\n            return self.message_port_pub(pmt.intern(\"\
      out\"), msg)\n\n        data = np.frombuffer(bytes(pmt.u8vector_elements(vec)),\
      \ dtype=np.uint8)\n        new_data = np.concatenate((data, self.pad))\n\n \
      \       meta = self._update_length_meta(meta, len(new_data))\n        new_vec\
      \ = pmt.init_u8vector(len(new_data), new_data.tolist())\n        new_msg = pmt.cons(meta,\
      \ new_vec)\n        self.message_port_pub(pmt.intern(\"out\"), new_msg)\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    pad_len: '256'
    pattern_byte: '0x55'
  states:
    _io_cache: ('pdu_padder', 'pdu_padder', [('pad_len', '256'), ('pattern_byte',
      '85')], [('in', 'message', 1)], [('out', 'message', 1)], '\n    Appends pad_len
      bytes with value pattern_byte to the end of each PDU:\n\n        [DATA] -> [DATA
      | PAD...]\n\n    DATA here is [HEADER | PAYLOAD | CRC] once we rewire.\n    ',
      ['pad_len', 'pattern_byte'])
    bus_sink: false
